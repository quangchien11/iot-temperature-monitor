<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Bảng màu hiện đại, đồng bộ với Web Dashboard (React + Ant Design) -->
    <Color x:Key="Primary">#1677FF</Color>
    <Color x:Key="PrimaryDark">#0958D9</Color>
    <Color x:Key="Accent">#36CFC9</Color>
    <Color x:Key="Secondary">#6C757D</Color>
    <Color x:Key="Tertiary">#13C2C2</Color>

    <Color x:Key="Danger">#FF4D4F</Color>
    <Color x:Key="Warning">#FA8C16</Color>
