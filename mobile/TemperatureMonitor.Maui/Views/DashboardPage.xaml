<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TemperatureMonitor.Maui.Views.DashboardPage"
             Title="Tổng quan"
             BackgroundColor="{StaticResource PageBg}">

    <RefreshView x:Name="Refresh" Refreshing="OnRefreshing">
        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="16">

                <!-- Banner cảnh báo -->
                <Border x:Name="AlertBanner" IsVisible="False" Padding="14"
                        Stroke="Transparent" BackgroundColor="{StaticResource Danger}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="⚠" FontSize="22" TextColor="White" VerticalOptions="Center" />
                        <Label x:Name="AlertText" TextColor="White" FontAttributes="Bold"
                               VerticalOptions="Center"
                               Text="CẢNH BÁO: Nhiệt độ vượt ngưỡng!" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Thẻ nhiệt độ lớn (gradient) -->
                <Border Padding="24" Stroke="Transparent">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                            <GradientStop Color="{StaticResource Accent}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource Primary}" Offset="0,8" Radius="18" Opacity="0.35" />
                    </Border.Shadow>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                        <Label Text="🌡  Nhiệt độ hiện tại" TextColor="#E6F0FF"
                               HorizontalOptions="Center" FontSize="14" />
                        <Label x:Name="LblTemp" Text="-- °C" FontSize="60" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" />
                        <Border x:Name="StatusBadge" Padding="14,5" Margin="0,6,0,0"
                                Stroke="Transparent" BackgroundColor="#33FFFFFF">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Label x:Name="LblStatus" Text="● BÌNH THƯỜNG" TextColor="White"
                                   FontAttributes="Bold" FontSize="13" HorizontalOptions="Center" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!-- Hàng 3 thẻ nhỏ -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                    <Border Grid.Column="0" BackgroundColor="{StaticResource CardBg}" Padding="12" Stroke="Transparent">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="#99A8C0" Offset="0,3" Radius="10" Opacity="0.18" /></Border.Shadow>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                            <Label Text="💧" FontSize="18" HorizontalOptions="Center" />
                            <Label Text="Độ ẩm" TextColor="{StaticResource Gray500}" FontSize="12" HorizontalOptions="Center" />
                            <Label x:Name="LblHumid" Text="--%" FontSize="20" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" BackgroundColor="{StaticResource CardBg}" Padding="12" Stroke="Transparent">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="#99A8C0" Offset="0,3" Radius="10" Opacity="0.18" /></Border.Shadow>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                            <Label Text="▲" FontSize="16" TextColor="{StaticResource Warning}" HorizontalOptions="Center" />
                            <Label Text="Cao nhất" TextColor="{StaticResource Gray500}" FontSize="12" HorizontalOptions="Center" />
                            <Label x:Name="LblMax" Text="--°" FontSize="20" FontAttributes="Bold"
                                   TextColor="{StaticResource Warning}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2" BackgroundColor="{StaticResource CardBg}" Padding="12" Stroke="Transparent">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="#99A8C0" Offset="0,3" Radius="10" Opacity="0.18" /></Border.Shadow>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                            <Label Text="▼" FontSize="16" TextColor="{StaticResource Tertiary}" HorizontalOptions="Center" />
                            <Label Text="Thấp nhất" TextColor="{StaticResource Gray500}" FontSize="12" HorizontalOptions="Center" />
                            <Label x:Name="LblMin" Text="--°" FontSize="20" FontAttributes="Bold"
                                   TextColor="{StaticResource Tertiary}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Cấu hình cảnh báo -->
                <Border BackgroundColor="{StaticResource CardBg}" Padding="18" Stroke="Transparent">
                    <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                    <Border.Shadow><Shadow Brush="#99A8C0" Offset="0,3" Radius="10" Opacity="0.18" /></Border.Shadow>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="⚙  Cấu hình cảnh báo" FontAttributes="Bold" FontSize="16"
                               TextColor="{StaticResource Gray900}" />
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="12">
                            <Label Grid.Row="0" Grid.Column="0" Text="Ngưỡng tối đa (°C)" VerticalOptions="Center"
                                   TextColor="{StaticResource Gray900}" />
                            <Entry Grid.Row="0" Grid.Column="1" x:Name="EntryMax" Keyboard="Numeric"
                                   WidthRequest="90" HorizontalTextAlignment="Center" />
                            <Label Grid.Row="1" Grid.Column="0" Text="Bật cảnh báo" VerticalOptions="Center"
                                   TextColor="{StaticResource Gray900}" />
                            <Switch Grid.Row="1" Grid.Column="1" x:Name="SwitchActive" HorizontalOptions="End"
                                    OnColor="{StaticResource Success}" ThumbColor="White" />
                        </Grid>
                        <Button Text="💾  Lưu cấu hình" Clicked="OnSaveAlert"
                                BackgroundColor="{StaticResource Primary}" TextColor="White"
                                FontAttributes="Bold" CornerRadius="12" HeightRequest="46" />
                        <Label x:Name="LblSaveMsg" TextColor="{StaticResource Success}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <Label x:Name="LblUpdated" Text="" TextColor="{StaticResource Gray500}" FontSize="12" HorizontalOptions="Center" />
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
