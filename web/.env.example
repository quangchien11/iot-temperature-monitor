# Cấu hình frontend React (Vite). Copy file này thành `.env.local` rồi chỉnh.
#
# VITE_API_BASE: gốc URL của API ASP.NET Core.
#   - Để TRỐNG (mặc định): dùng đường dẫn tương đối cùng origin.
#       + `npm run dev`  -> Vite proxy /api sang http://localhost:5094
#       + build vào wwwroot -> API tự phục vụ web, cùng origin
#   - Đặt giá trị (chạy FE độc lập, tách hẳn backend), ví dụ:
#       VITE_API_BASE=http://localhost:5094
#     hoặc trỏ tới server thật:
#       VITE_API_BASE=https://api.your-domain.com
#
# Lưu ý: khi đặt VITE_API_BASE tới origin khác, API phải bật CORS (đã bật sẵn: policy "AllowAll").
VITE_API_BASE=
